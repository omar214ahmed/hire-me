# Read by docker-compose.yml itself (variable substitution: ${VAR}), NOT
# passed into containers directly — this file must live next to
# docker-compose.yml (repo root), not inside ats/ or hr/.

# Postgres password shared between the `postgres` service and the
# DATABASE_URL that docker-compose builds for the `ats`/`ats-worker`
# services.
POSTGRES_PASSWORD=changeme

# Host-side folder containing your pre-exported ONNX models
# (gliner/, bge-m3-int8/, bge-reranker-int8/ subfolders — see the ATS
# README for how these are produced). Mounted read-only into the ats/
# ats-worker containers at /app/onnx_models.
ONNX_MODELS_DIR=/home/omar-ahmed/onnx_models
