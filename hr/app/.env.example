APP_NAME = "HR system"
APP_VERSION = "1.0.0"
ALLOWED_MIME_TYPES = ["audio/mpeg", "audio/wav", "audio/x-wav", "audio/ogg", "audio/aac", "audio/flac", "audio/mp4"]
MAX_FILE_SIZE_MB = 10
WHISPER_MODEL_SIZE = "small"
# "cpu" by default so the container runs anywhere without a GPU.
# Set to "gpu"/"cuda" only if you're running this on a machine with an
# NVIDIA GPU + the matching ctranslate2/CUDA runtime available.
WHISPER_DEVICE = "cpu"
WHISPER_COMPUTE_TYPE = "int8"
LLM_MAX_NEW_TOKENS = 250
LLM_TEMPERATURE = 0.1
LLM_TIMEOUT = 300
LLM_OLLAMA_MODEL = "qwen2.5:3b"

# -----------------------------
# ATS integration (microservice)
# -----------------------------
# Inside Docker Compose this MUST be the ATS's service name, never
# localhost/127.0.0.1 (see docker-compose.yml at the repo root).
ATS_API_URL = "http://ats:8000"
ATS_REQUEST_TIMEOUT = 5.0
ATS_MAX_RETRIES = 3
ATS_RETRY_BACKOFF_SECONDS = 0.5
